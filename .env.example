ANTHROPIC_API_KEY=       # Claude orchestration model
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=          # OpenAI text-embedding-3-small for pgvector retrieval
DATABASE_URL=            # PostgreSQL with pgvector extension
REDIS_URL=               # Redis for BullMQ reindex jobs
CONCIERGE_TOKEN_KEY=     # 32-byte AES key, hex/base64/plain utf8
CONCIERGE_API_KEY=       # shared MCP/backend key for Claude Desktop demo
CONCIERGE_API_URL=       # used by MCP/registry web, e.g. http://localhost:3000
CONCIERGE_PUBLIC_URL=    # public callback base URL for approval links
CONCIERGE_AGENT_MODE=    # set to demo for deterministic local/mock Railway demos
RAILWAY_API_BASE_URL=    # mock or real Railway-compatible API base URL
CLICKHOUSE_URL=          # intent-graph analytics store (post-MVP)
